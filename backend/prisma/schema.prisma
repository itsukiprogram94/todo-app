// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// こっから下がTodoの要件
model Todo {
  id          Int      @id @default(autoincrement()) // 自動で1, 2, 3...と連番になるID
  title       String   // Todoのタイトル（文字）
  isCompleted Boolean  @default(false) // 完了したかどうかの判定（最初は「未完了」なので false）
  createdAt   DateTime @default(now()) // 作成された日時（自動で今の時間が入る）
  // 新しく追加する2つの項目
  description String?    // 詳細説明（? は「空っぽでもOK」という意味です）
  dueDate     DateTime?  // 期限日（こちらも「設定しなくてもOK」としています）
  tags         Tag[]
}

// タグのモデル（箱）を新設
model Tag {
  id    Int     @id @default(autoincrement())
  name  String  @unique  // @unique: 同じ名前のタグは作れないようにする設定
  color String?          // タグの色（"#FF0000" のようなカラーコードを入れる想定）
  todos Todo[]
}